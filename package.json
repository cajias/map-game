{
  "name": "map-game",
  "version": "1.0.0",
  "description": "A simple map game",
  "main": "dist/index.js",
  "repository": "https://github.com/cajias/map-game.git",
  "author": "Rul & Beg",
  "license": "MIT",
  "private": true,
  "packageManager": "yarn@3.2.2",
  "scripts": {
    "clean": "git clean -fdx",
    "test:pre": "rm -rf dist && rm -rf coverage && yarn lint && tsc",
    "test": "yarn test:pre && yarn jest",
    "test:ci": "yarn test:pre && yarn jest --coverage && yarn test:post",
    "test:bump": "jest-coverage-thresholds-bumper --silent --margin 1",
    "test:ci-badges": "coverage-badges",
    "test:post": "yarn test:bump && yarn test:ci-badges",
    "lint": "eslint",
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "postinstall": "husky install"
  },
  "dependencies": {
    "terminal-canvas": "^3.1.2",
    "yargs": "^17.5.1"
  },
  "devDependencies": {
    "@types/jest": "^28.1.7",
    "@types/node": "^18.7.6",
    "@types/yargs": "^17.0.11",
    "@typescript-eslint/eslint-plugin": "^5.33.1",
    "@typescript-eslint/parser": "^5.33.1",
    "coverage-badges-cli": "^1.0.10",
    "eslint": "^8.22.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.1",
    "jest": "^28.1.3",
    "jest-coverage-thresholds-bumper": "^1.1.0",
    "lint-staged": "^13.0.3",
    "minimist": "^1.2.6",
    "prettier": "2.7.1",
    "ts-jest": "^28.0.8",
    "ts-node": "^10.9.1",
    "tslib": "^2.4.0",
    "typescript": "^4.7.4"
  },
  "jest": {
    "coverageReporters": [
      "json-summary",
      "text"
    ],
    "preset": "ts-jest",
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": [
      "<rootDir>/**/*.test.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 91.66,
        "lines": 100,
        "statements": 96.96
      }
    }
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "commonjs": true,
      "es2021": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:prettier/recommended"
    ],
    "overrides": [],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "ecmaVersion": "latest"
    },
    "plugins": [
      "prettier",
      "@typescript-eslint"
    ],
    "rules": {
      "prettier/prettier": "error",
      "no-unused-vars": "off",
      "@typescript-eslint/no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_",
          "caughtErrorsIgnorePattern": "^_"
        }
      ]
    }
  },
  "lint-staged": {
    "*.{js,ts,css,md,json}": "prettier --write",
    "*.{ts}": "eslint --cache --fix"
  }
}
